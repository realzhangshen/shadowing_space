# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local

# ──────────────────────────────────────────────
# Site URL (used for SEO / Open Graph metadata)
# ──────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ──────────────────────────────────────────────
# YouTube proxy (optional, comma-separated URLs)
# ──────────────────────────────────────────────
# YOUTUBE_PROXY_URLS=https://proxy1.example.com,https://proxy2.example.com

# Timeout for YouTube fetches in milliseconds (default: 15000)
# YOUTUBE_FETCH_TIMEOUT_MS=15000

# ──────────────────────────────────────────────
# Rate limiting
# ──────────────────────────────────────────────
# Max transcript requests per window (default: 30)
# TRANSCRIPT_RATE_LIMIT_MAX_REQUESTS=30

# Rate limit window in milliseconds (default: 60000)
# TRANSCRIPT_RATE_LIMIT_WINDOW_MS=60000

# ──────────────────────────────────────────────
# Track token security
# ──────────────────────────────────────────────
# REQUIRED in production — used to sign transcript track tokens.
# Must be a strong random string (e.g. openssl rand -base64 32).
# TRACK_TOKEN_SECRET=

# Token time-to-live in seconds (default: 86400 = 24 hours)
# TRACK_TOKEN_TTL_SECONDS=86400

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
