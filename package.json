    "next-intl": "^4.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "undici": "^7.22.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
