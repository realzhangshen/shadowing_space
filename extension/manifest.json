{
  "manifest_version": 3,
  "name": "Shadowing Space Importer",
  "version": "0.3.1",
  "description": "Import YouTube captions into Shadowing Space using the viewer's own browser network.",
  "permissions": ["tabs", "scripting", "storage", "downloads"],
  "host_permissions": ["https://www.youtube.com/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Import into Shadowing Space",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["youtube-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["youtube-main.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://shadowing.space/*",
        "https://www.shadowing.space/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["shadowing-space-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
